# runners versions
# https://github.com/dosbox-staging/dosbox-staging/releases
DOSBOX_STAGING_VER=0.82.2
# https://github.com/joncampbell123/dosbox-x/releases
DOSBOX_X_VER=2025.12.01
DOSBOX_VER=0.74-3
#
QEMU_VER=latest
# https://github.com/scummvm/scummvm/releases
SCUMMVM_VER=2026.2.0
# https://buildbot.libretro.com/stable
RETROARCH_VER=1.21.0
# https://gitlab.winehq.org/wine/wine/-/releases
WINE_BRANCH=stable
WINE_VER=11.0

# genesis images
DOCKER_GENESIS_IMAGE=debian:trixie-slim
NVIDIA_DOCKER_GENESIS_IMAGE=debian:trixie-slim

# cpu | gpu-intel | gpu-nvidia
VIDEO_ENC=gpu-nvidia
# x11 | wayland
WINDOW_SYSTEM=x11

# streamd log level: DEBUG
STREAMD_LOG_LEVEL=3

# os env vars
USERNAME=gamer
